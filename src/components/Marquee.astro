---
interface Props {
  text: string;
  bgColor?: string;
  textColor?: string;
  borderColor?: string;
}

const { 
  text, 
  bgColor = `var(--clr-gold)`, 
  textColor = `var(--clr-blue)`, 
  borderColor = `var(--clr-blue)` 
} = Astro.props;
---

<div class="marquee-container" style={`background-color: ${bgColor}; color: ${textColor}; border-color: ${borderColor};`}>
    <div class="marquee-text">
        <span>{text}</span>
        <span>{text}</span>
        <span>{text}</span>
        <span>{text}</span>
    </div>
</div>

<style>
    .marquee-container {
        padding: 12px 0;
        overflow: hidden;
        white-space: nowrap;
        border-bottom: 3px solid;
        z-index: 10;
        position: relative;
    }

    .marquee-text {
        display: inline-block;
        animation: marquee 20s linear infinite;
        font-family: var(--font-display);
        font-size: 1.2rem;
        letter-spacing: 2px;
    }

    .marquee-text span {
        margin: 0 40px;
    }

    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
</style>