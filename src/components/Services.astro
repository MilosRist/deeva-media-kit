---
import Marquee from './Marquee.astro';
---

<Marquee text="RATES & SERVICES ↓↓ RATES & SERVICES ↓↓" bgColor="var(--clr-cream)" textColor="var(--clr-blue)" borderColor="var(--clr-red)" />

<section class="services">
    <h2 class="services-title">Rates</h2>

    <div class="services-layout">
        <div class="rates-grid">
            <div class="rate-item">
                <span class="rate-platform">TikTok Post</span>
                <span class="rate-price">$5,000</span>
            </div>
            <div class="rate-item secondary">
                <span class="rate-platform">Instagram Reel</span>
                <span class="rate-price">$1,500</span>
            </div>
            <div class="rate-item">
                <span class="rate-platform">IG Stories (3 Frames)</span>
                <span class="rate-price">$300</span>
            </div>
            <div class="rate-item secondary">
                <span class="rate-platform">Carousel Post</span>
                <span class="rate-price">$1,500</span>
            </div>
            <div class="rate-item">
                <span class="rate-platform">Exclusivity</span>
                <span class="rate-price">$500/mo</span>
            </div>
        </div>

        <div class="offerings-box">
            <h3>What I Offer</h3>
            <ul>
                <li>Recipes & Dedicated Blog Posts</li>
                <li>Sponsored TikToks, IG Reels & Youtube</li>
                <li>Honest Product Reviews</li>
                <li>Food, Travel & Lifestyle Storytelling</li>
            </ul>
            <div>
                <p class="fine-print">*Custom deals & packages available upon request</p>
            </div>
        </div>
    </div>

    <div class="brands-section">
        <h3 class="brands-title">Some Brands I've Worked With...</h3>
        <div class="brands-placeholder-grid">
            <!-- Replace these divs with actual brand logos -->
            <img src="/uber-eats-logo.png" alt="Uber Eats Logo" class="logo-placeholder">
            <img src="/a&w-logo.svg" alt="A&W Logo" class="logo-placeholder">
            <img src="/clover-leaf-logo.png" alt="Clover Leaf Logo" class="logo-placeholder">
            <img src="/havoc-logo.svg" alt="Havoc Logo" class="logo-placeholder">
            <img src="/hilton-logo.png" alt="Hilton Logo" class="logo-placeholder">
            <img src="/kitkat-logo.png" alt="KitKat Logo" class="logo-placeholder">
            <img src="/tim-hortons-logo.png" alt="Tim Hortons Logo" class="logo-placeholder">
            <img src="/netflix-logo.png" alt="Netflix Logo" class="logo-placeholder">
        </div>
    </div>
</section>

<style>
    .services {
        background-color: var(--clr-cream);
        padding: 100px 5%;
        color: var(--clr-blue);
    }

    .services-title {
        font-family: var(--font-display);
        font-size: clamp(3rem, 8vw, 8rem);
        line-height: 1;
        text-transform: uppercase;
        color: var(--clr-blue);
        -webkit-text-stroke: 3px var(--clr-red);
        margin-bottom: 60px;
        text-align: center;
    }

    .services-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        margin-bottom: 80px;
    }

    .rates-grid {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .rate-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--clr-blue);
        color: var(--clr-gold);
        padding: 25px;
        border: 3px solid var(--clr-red);
        box-shadow: 8px 8px 0px var(--clr-orange);
    }

    .rate-item.secondary {
        background: var(--clr-red);
        color: var(--clr-gold);
        border-color: var(--clr-blue);
        box-shadow: 8px 8px 0px var(--clr-orange);
    }

    .rate-platform {
        font-family: var(--font-display);
        font-size: 1.2rem;
        text-transform: uppercase;
    }

    .rate-price {
        font-family: var(--font-display);
        font-size: 2rem;
    }

    .offerings-box {
        background: #F6EEE3;
        padding: 40px;
        border: 4px solid var(--clr-orange);
        box-shadow: 12px 12px 0px var(--clr-blue);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .offerings-box h3 {
        font-family: var(--font-display);
        font-size: 2rem;
        color: var(--clr-red);
        margin-bottom: 20px;
        text-transform: uppercase;
    }

    .offerings-box ul {
        list-style: none;
        margin-bottom: 30px;
    }

    .offerings-box li {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 15px;
        padding-left: 30px;
        position: relative;
    }

    .offerings-box li::before {
        content: '★';
        position: absolute;
        left: 0;
        color: var(--clr-orange);
    }

    .fine-print {
        font-size: 0.9rem;
        color: var(--clr-blue);
        font-weight: 700;
        border-top: 2px dashed var(--clr-orange);
        padding-top: 15px;
    }

    .brands-section {
        text-align: center;
    }

    .brands-title {
        font-family: var(--font-display);
        font-size: 1.5rem;
        margin-bottom: 40px;
        text-transform: uppercase;
    }

    .brands-placeholder-grid {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 20px;
    }

    .logo-placeholder {
        width: 140px;
        height: 70px;
        background-color: rgba(0, 48, 73, 0.1);
        /* border: 2px dashed var(--clr-blue); */
        border-radius: 4px; /* Just a subtle radius for logos */
        padding: 5px;
    }

    @media (max-width: 900px) {
        .services-layout {
            grid-template-columns: 1fr;
        }
    }
</style>